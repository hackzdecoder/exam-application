@{
    ViewData["Title"] = "Home Page";
}

<!DOCTYPE html>
<html>
<head>
<style>
table {
  font-family: arial, sans-serif;
  border-collapse: collapse;
  width: 100%;
}

td, th {
  border: 1px solid #dddddd;
  text-align: left;
  padding: 8px;
}

tr:nth-child(even) {
  background-color: #dddddd;
}

#edit-form {
  margin-top: 20px;
  padding: 10px;
  border: 1px solid #cccccc;
  width: 300px;
}

#edit-form {
    display: none;
}

button {
    color: white;
  margin-top: 10px;
  padding: 5px 10px;
    background-color: #4CAF50;}

</style>
</head>
<body>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Type</th>
      <th>Stock</th>
      <th>Price</th>
      <th>Actions</th>
    </tr>
  </thead>
<tbody id="fruits-table-body"></tbody>
<button onclick="addFruit();">Add Fruit</button>

<div id="edit-form" >
    <h3 id="edit-title"></h3>
    <input type="hidden" id="fruit-id" name="fruit-id">
    <label for="fruit-name">Name:</label>
    <input type="text" id="fruit-name" name="fruit-name"><br><br>
    <label for="fruit-type">Type:</label>
    <input type="text" id="fruit-type" name="fruit-type"><br><br>
    <label for="fruit-stock">Stock:</label>
    <input type="number" id="fruit-stock" name="fruit-stock"><br><br>
    <label for="fruit-price">Price:</label>
    <input type="number" step="0.01" id="fruit-price" name="fruit-price"><br><br>
    <button onclick="saveData()">SAVE</button>
</div>
</table>
<script>
        
        addFruit = () => {
            const form = document.getElementById("edit-form");
            document.getElementById("edit-title").innerText = "Add New Fruit";  
            form.style.display = form.style.display === "none" ? "block" : "none";
        }        

        editFruit = (id) => {
            const form = document.getElementById("edit-form");
            document.getElementById("edit-title").innerText = "Edit Fruit";  
            form.style.display = form.style.display === "none" ? "block" : "none";

            // Fetch fruit data by ID and populate the form
            fetch(`http://localhost:5030/edit-fruits-inventory`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ id: id })
            }).then(response => response.json())
              .then(data => {
                  document.getElementById("fruit-id").value = data.data[0].ID;
                  document.getElementById("fruit-name").value = data.data[0].NAME;
                  document.getElementById("fruit-type").value = data.data[0].TYPE;
                  document.getElementById("fruit-stock").value = data.data[0].STOCK;
                  document.getElementById("fruit-price").value = data.data[0].PRICE;
              })
              .catch(error => console.error("Error fetching fruit data:", error));
        }

        saveData = () => {
            const id = document.getElementById("fruit-id").value;
            const name = document.getElementById("fruit-name").value;
            const type = document.getElementById("fruit-type").value;
            const stock = parseInt(document.getElementById("fruit-stock").value);
            const price = parseFloat(document.getElementById("fruit-price").value);

            if (id) {
                // Update existing fruit
                fetch(`http://localhost:5030/update-fruits-inventory/`, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ id, name, type, stock, price })
                }).then(response => response.json())
                  .then(data => {
                      alert("Fruit updated successfully!");
                      location.reload(); // Reload the page to show updated fruit list
                  })
                  .catch(error => console.error("Error updating fruit:", error));
            } else {
                // Add new fruit
                fetch("http://localhost:5030/add-fruits-inventory", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({ name, type, stock, price })
                }).then(response => response.json())
                  .then(data => {
                      alert("Fruit added successfully!");
                      location.reload(); // Reload the page to show updated fruit list
                  })
                  .catch(error => console.error("Error adding fruit:", error));
            }
        }

        @* Fetch all data *@
        fetch("http://localhost:5030/fruits-inventories", {
            "method": "GET",
            "headers": {
                "Content-Type": "application/json"
            }
        }).then(
            response => response.json()
        ).then(
            data => {
                const fruits = data.data;
                const tableBody = document.getElementById("fruits-table-body");
                fruits.forEach(fruit => {
                    const row = document.createElement("tr");
                    row.innerHTML = `
                        <td>${fruit.ID}</td>
                        <td>${fruit.NAME}</td>
                        <td>${fruit.TYPE}</td>
                        <td>${fruit.STOCK}</td>
                        <td>${fruit.PRICE}</td>
                        <td><button onclick="editFruit(${fruit.ID})">Edit</button></td>
                    `;
                    tableBody.appendChild(row);
                });
            }
        ).catch(
            error => console.error("Error fetching fruits inventories:", error)
        );
    </script>
</body>
</html>

