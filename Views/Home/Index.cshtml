@{
    ViewData["Title"] = "Home Page";
}

<!DOCTYPE html>
<html>
<head>
<style>
table {
  font-family: arial, sans-serif;
  border-collapse: collapse;
  width: 100%;
}

td, th {
  border: 1px solid #dddddd;
  text-align: left;
  padding: 8px;
}

tr:nth-child(even) {
  background-color: #dddddd;
}

#edit-form {
  margin-top: 20px;
  padding: 20px;
  border: 1px solid #cccccc;
  width: 300px;
  display: none;
  background-color: #f9f9f9;
  border-radius: 5px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
  transition: all 0.3s ease;
}

button {
  color: white;
  margin-top: 10px;
  padding: 5px 10px;
  background-color: #4CAF50;
  border: none;
  border-radius: 3px;
  cursor: pointer;
  margin-right: 5px;
}

button:hover {
  background-color: #45a049;
}

#cancelBtn {
  background-color: #f44343;
}

#cancelBtn:hover {
  background-color: #da190b;
}

.form-buttons {
  display: flex;
  gap: 10px;
}
</style>
</head>
<body>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Name</th>
      <th>Type</th>
      <th>Stock</th>
      <th>Price</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody id="fruits-table-body"></tbody>
</table>

<button id="addFruitBtn">Add Fruit</button>

<div id="edit-form">
    <h3 id="edit-title"></h3>
    <input type="hidden" id="fruit-id" name="fruit-id">
    <label for="fruit-name">Name:</label>
    <input type="text" id="fruit-name" name="fruit-name"><br><br>
    <label for="fruit-type">Type:</label>
    <input type="text" id="fruit-type" name="fruit-type"><br><br>
    <label for="fruit-stock">Stock:</label>
    <input type="number" id="fruit-stock" name="fruit-stock"><br><br>
    <label for="fruit-price">Price:</label>
    <input type="number" step="0.01" id="fruit-price" name="fruit-price"><br><br>
    <div class="form-buttons">
        <button id="saveBtn">SAVE</button>
        <button id="cancelBtn">CANCEL</button>
    </div>
</div>

<script>
    // Wait for DOM to be fully loaded
    document.addEventListener('DOMContentLoaded', function() {
        
        // Get DOM elements
        const form = document.getElementById("edit-form");
        const addBtn = document.getElementById("addFruitBtn");
        const saveBtn = document.getElementById("saveBtn");
        const cancelBtn = document.getElementById("cancelBtn");
        const tableBody = document.getElementById("fruits-table-body");
        
        // Load all fruits on page load
        loadFruits();
        
        // Add Fruit button click handler
        addBtn.addEventListener('click', function() {
            // Clear form
            document.getElementById("fruit-id").value = "";
            document.getElementById("fruit-name").value = "";
            document.getElementById("fruit-type").value = "";
            document.getElementById("fruit-stock").value = "";
            document.getElementById("fruit-price").value = "";
            
            // Set title and show form
            document.getElementById("edit-title").innerText = "Add New Fruit";  
            form.style.display = "block";
            
            // Scroll to form smoothly
            scrollToForm();
        });
        
        // Cancel button click handler
        cancelBtn.addEventListener('click', function() {
            form.style.display = "none";
        });
        
        // Save button click handler
        saveBtn.addEventListener('click', saveData);
        
        // Function to scroll to form
        function scrollToForm() {
            form.scrollIntoView({ 
                behavior: 'smooth', 
                block: 'center' 
            });
        }
        
        // Function to load all fruits
        function loadFruits() {
            @* fetch("http://localhost:5030/fruits-inventories", { *@
            fetch("https://unconcentrative-marhta-pencillike.ngrok-free.dev/fruits-inventories", {
                method: "GET",
                headers: {
                    "Content-Type": "application/json"
                }
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Network response was not ok');
                }
                return response.json();
            })
            .then(data => {
                const fruits = data.data;
                tableBody.innerHTML = ""; // Clear existing rows
                
                fruits.forEach(fruit => {
                    const row = document.createElement("tr");
                    row.innerHTML = `
                        <td>${fruit.ID}</td>
                        <td>${fruit.NAME}</td>
                        <td>${fruit.TYPE}</td>
                        <td>${fruit.STOCK}</td>
                        <td>${parseFloat(fruit.PRICE).toFixed(2)}</td>
                        <td><button class="edit-btn" data-id="${fruit.ID}">Edit</button></td>
                    `;
                    tableBody.appendChild(row);
                });
                
                // Add event listeners to all edit buttons
                document.querySelectorAll('.edit-btn').forEach(btn => {
                    btn.addEventListener('click', function() {
                        const id = this.getAttribute('data-id');
                        editFruit(id);
                    });
                });
            })
            .catch(error => {
                console.error("Error fetching fruits inventories:", error);
                alert("Failed to load fruits. Please check if the server is running.");
            });
        }
        
        // Edit function
        function editFruit(id) {
            // Show form
            document.getElementById("edit-title").innerText = "Edit Fruit";  
            form.style.display = "block";
            
            // Scroll to form smoothly
            scrollToForm();

            // Fetch fruit data by ID
            @* fetch(`http://localhost:5030/edit-fruits-inventory`, { *@
            fetch(`https://unconcentrative-marhta-pencillike.ngrok-free.dev/edit-fruits-inventory`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ id: id })
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Network response was not ok');
                }
                return response.json();
            })
            .then(data => {
                document.getElementById("fruit-id").value = data.data[0].ID;
                document.getElementById("fruit-name").value = data.data[0].NAME;
                document.getElementById("fruit-type").value = data.data[0].TYPE;
                document.getElementById("fruit-stock").value = data.data[0].STOCK;
                document.getElementById("fruit-price").value = data.data[0].PRICE;
            })
            .catch(error => {
                console.error("Error fetching fruit data:", error);
                alert("Failed to fetch fruit data.");
            });
        }
        
        // Save function
        function saveData() {
            const id = document.getElementById("fruit-id").value;
            const name = document.getElementById("fruit-name").value;
            const type = document.getElementById("fruit-type").value;
            const stock = parseInt(document.getElementById("fruit-stock").value);
            const price = parseFloat(document.getElementById("fruit-price").value);

            // Validate inputs
            if (!name || !type || !stock || !price) {
                alert("Please fill in all fields");
                return;
            }

            let url, method;
            let bodyData;

            if (id) {
                // Update existing fruit
                @* url = "http://localhost:5030/update-fruits-inventory/"; *@
                url = "https://unconcentrative-marhta-pencillike.ngrok-free.dev/update-fruits-inventory/";
                bodyData = JSON.stringify({ id, name, type, stock, price });
            } else {
                // Add new fruit
                @* url = "http://localhost:5030/add-fruits-inventory"; *@
                url = "https://unconcentrative-marhta-pencillike.ngrok-free.dev/add-fruits-inventory";
                bodyData = JSON.stringify({ name, type, stock, price });
            }

            fetch(url, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: bodyData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Network response was not ok');
                }
                return response.json();
            })
            .then(data => {
                alert(id ? "Fruit updated successfully!" : "Fruit added successfully!");
                form.style.display = "none"; // Hide form
                loadFruits(); // Reload the fruits list
                
                // Optional: Scroll back to top
                window.scrollTo({
                    top: 0,
                    behavior: 'smooth'
                });
            })
            .catch(error => {
                console.error("Error saving fruit:", error);
                alert("Failed to save fruit. Please try again.");
            });
        }
    });
</script>
</body>
</html>